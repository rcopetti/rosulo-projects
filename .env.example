# ========================================
# Application
# ========================================
APP_NAME="PM AI Platform"
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# ========================================
# Database (PostgreSQL)
# ========================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pm_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ========================================
# Redis
# ========================================
REDIS_URL=redis://localhost:6379/0

# ========================================
# JWT Authentication
# ========================================
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# OAuth Providers
# ========================================
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ========================================
# AWS
# ========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bedrock Models
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
AWS_BEDROCK_HAIKU_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# S3
AWS_S3_VECTORS_BUCKET=pm-ai-vectors
AWS_S3_DOCUMENTS_BUCKET=pm-ai-documents

# ========================================
# AI Guardrails
# ========================================
AI_MAX_TOKENS_PER_REQUEST=4096
AI_DAILY_BUDGET_USD=50.0
AI_MONTHLY_BUDGET_USD=500.0
AI_MAX_CONVERSATION_HISTORY=50
AI_CONTENT_SAFETY_ENABLED=true

# ========================================
# LiteLLM
# ========================================
LITELLM_PROVIDER=bedrock
LITELLM_API_BASE=

# ========================================
# CORS
# ========================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ========================================
# Frontend (Vite)
# ========================================
VITE_API_URL=http://localhost:6010/api/v1
